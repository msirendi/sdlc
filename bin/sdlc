#!/usr/bin/env bash
# Wrapper that invokes the SDLC pipeline runner from any directory.
#
# Usage:
#   sdlc                     # run against $PWD
#   sdlc /path/to/repo       # run against a specific repo
#   sdlc --dry-run           # forward flags straight through
#   sdlc /path/to/repo --only 12-ultra-review.md
set -euo pipefail

# Resolve the directory that actually contains this script, following symlinks
# so the wrapper works when installed via `ln -s` into a PATH directory.
_resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -h "$src" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd
}

_BIN_DIR="$(_resolve_script_dir)"
: "${SDLC_HOME:="$(cd "$_BIN_DIR/.." >/dev/null 2>&1 && pwd)"}"
export SDLC_HOME

repo_path="$PWD"
if [[ $# -gt 0 && "$1" != -* ]]; then
  repo_path="$1"
  shift
fi

exec "$SDLC_HOME/orchestrator/run-pipeline.sh" --repo "$repo_path" "$@"

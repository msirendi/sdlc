#!/usr/bin/env bash
# Wrapper that seeds .sdlc/ scaffolding in a target repository.
#
# Usage:
#   sdlc-init                 # initialize the repo at $PWD
#   sdlc-init /path/to/repo   # initialize a specific repo
set -euo pipefail

_resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -h "$src" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd
}

_BIN_DIR="$(_resolve_script_dir)"
: "${SDLC_HOME:="$(cd "$_BIN_DIR/.." >/dev/null 2>&1 && pwd)"}"
export SDLC_HOME

exec "$SDLC_HOME/orchestrator/init-target-repo.sh" "${1:-$PWD}"
